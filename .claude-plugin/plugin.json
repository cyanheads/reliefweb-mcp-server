{
  "name": "@cyanheads/reliefweb-mcp-server",
  "version": "0.1.9",
  "description": "Search ReliefWeb humanitarian reports, disasters, jobs, training, and country profiles via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/reliefweb-mcp-server#readme",
  "repository": "https://github.com/cyanheads/reliefweb-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/reliefweb-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/reliefweb-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "RELIEFWEB_APP_NAME": "your-app-name"
      }
    }
  }
}
